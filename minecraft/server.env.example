# --- Server Execution Control ---
# Set to 'false' to disable automatic restarts after a crash or shutdown
CKCA_RESTART=false

# Set to 'true' to only run the installer and exit
CKCA_INSTALL_ONLY=false

# Full path to the Java executable (if not in PATH)
# CKCA_JAVA=java

# --- EULA ---
# Set to 'true' to automatically accept the Minecraft EULA
CKCA_AGREE_EULA=true

# --- Memory Settings ---
# Maximum and Minimum RAM allocation (e.g., 4G, 8192M)
CKCA_MAX_RAM=8G
# CKCA_MIN_RAM=4G

# --- JVM Optimization Toggles ---
# Use Aikar's optimized flags (Highly recommended for G1GC)
CKCA_USE_AIKAR=true

# Garbage Collector Type: G1GC, ZGC, or Shenandoah
# Note: ZGC requires Java 15+ and is great for low latency
CKCA_GC_TYPE=G1GC

# Extra JVM arguments not covered by other toggles
# CKCA_EXTRA_JVM_ARGS=""
